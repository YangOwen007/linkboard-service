{
  "name": "linkboard-service",
  "version": "0.1.0",
  "private": true,
  "description": "Production-minded link-in-bio analytics service built with Fastify, TypeScript, Prisma, and PostgreSQL.",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.15.1"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "pino-pretty": "^13.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "prisma": "^6.11.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
